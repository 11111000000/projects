<BaseLayout title="Отчёт по проектам" description="Диалектический отчёт по проектам" active="report">
  <Fragment slot="topbar">
      <div>
        <div class="eyebrow">Отчёт</div>
        <h1>Сбор данных, анализ, публикация</h1>
      <p class="lead">Сводка по проектам, где каждый блок показывает только новый смысл.</p>
      </div>
  </Fragment>

  <Fragment slot="sidebar">
    <DashboardSidebar projects={projects} active="report" />
  </Fragment>

  <section class="stage llm-stage">
    <header>
      <span class="step-num">01</span>
      <h2>Аналитика LLM</h2>
    </header>

    <div class="llm-charts-grid">
      <script id="llmChartData" type="application/json" set:html={JSON.stringify(llmChartData)}></script>
      <script id="llmTopModels" type="application/json" set:html={JSON.stringify(llmTopModels)}></script>
      <div class="llm-chart-card llm-chart-card-wide">
        <h4>Динамика и структура затрат по месяцам, ₽</h4>
        <canvas id="llmChartMonthly"></canvas>
        <div class="llm-chart-legend llm-chart-legend-inline">
          <span><i class="legend-swatch premium"></i>Premium</span>
          <span><i class="legend-swatch mid"></i>Mid</span>
          <span><i class="legend-swatch budget"></i>Budget</span>
          <span><i class="legend-swatch total"></i>Total</span>
        </div>
      </div>
      <div class="llm-chart-card">
        <h4>Доли за 30 дней (Интерактив)</h4>
        <canvas id="llmChartTier"></canvas>
      </div>
      <div class="llm-chart-card">
        <h4>Топ моделей (доля от бюджета)</h4>
        <canvas id="llmChartModels"></canvas>
      </div>
    </div>

    <div class="llm-optimization-note">
      <div class="opt-badge success">Апрель: Budget+Mid = {llmData.tierApr.budget + llmData.tierApr.mid}%</div>
      <span>Стоимость запроса: {llmData.aprCpr} ₽.</span>
    </div>
  </section>

  <script>
    function readJson(id, fallback) {
      var node = document.getElementById(id);
      if (!node) return fallback;
      var text = node.textContent || '';
      if (!text.trim()) return fallback;
      try {
        return JSON.parse(text);
      } catch (e) {
        return fallback;
      }
    }

    function drawBar(canvas, labels, values, colors, opts) {
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;
      var width = canvas.width = canvas.clientWidth * devicePixelRatio;
      var height = canvas.height = canvas.clientHeight * devicePixelRatio;
      ctx.save();
      ctx.scale(devicePixelRatio, devicePixelRatio);
      ctx.clearRect(0, 0, canvas.clientWidth, canvas.clientHeight);
      var padL = opts.padL || 120;
      var padR = opts.padR || 20;
      var padT = opts.padT || 24;
      var padB = opts.padB || 32;
      var w = canvas.clientWidth - padL - padR;
      var h = canvas.clientHeight - padT - padB;
      var max = opts.max || Math.max.apply(Math, values);
      var barH = Math.max(12, (h / values.length) * 0.58);
      ctx.font = '12px ui-monospace, monospace';
      ctx.textBaseline = 'middle';
      for (var i = 0; i < values.length; i++) {
        var y = padT + (h / values.length) * i + ((h / values.length) - barH) / 2;
        var barW = Math.max(1, (values[i] / max) * w);
        ctx.fillStyle = colors[i] || '#7c3aed';
        roundRect(ctx, padL, y, barW, barH, 8);
        ctx.fill();
        ctx.fillStyle = 'rgba(15,23,42,0.9)';
        ctx.fillText(labels[i], 16, y + barH / 2);
        ctx.textAlign = 'right';
        ctx.fillText(Number(values[i]).toLocaleString('ru-RU') + ' ₽', padL + barW - 8, y + barH / 2);
        ctx.textAlign = 'left';
      }
      ctx.restore();
    }

    function roundRect(ctx, x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + w - r, y);
      ctx.quadraticCurveTo(x + w, y, x + w, y + r);
      ctx.lineTo(x + w, y + h - r);
      ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
      ctx.lineTo(x + r, y + h);
      ctx.quadraticCurveTo(x, y + h, x, y + h - r);
      ctx.lineTo(x, y + r);
      ctx.quadraticCurveTo(x, y, x + r, y);
      ctx.closePath();
    }

    function drawDonut(canvas, items) {
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;
      canvas.width = canvas.clientWidth * devicePixelRatio;
      canvas.height = canvas.clientHeight * devicePixelRatio;
      ctx.save();
      ctx.scale(devicePixelRatio, devicePixelRatio);
      ctx.clearRect(0, 0, canvas.clientWidth, canvas.clientHeight);
      var cx = canvas.clientWidth / 2;
      var cy = canvas.clientHeight / 2 - 6;
      var radius = Math.min(canvas.clientWidth, canvas.clientHeight) * 0.28;
      var inner = radius * 0.62;
      var total = items.reduce(function(sum, item) { return sum + item.value; }, 0);
      var start = -Math.PI / 2;
      for (var i = 0; i < items.length; i++) {
        var slice = items[i].value / total * Math.PI * 2;
        ctx.beginPath();
        ctx.strokeStyle = items[i].color;
        ctx.lineWidth = radius - inner;
        ctx.arc(cx, cy, (radius + inner) / 2, start, start + slice);
        ctx.stroke();
        start += slice;
      }
      ctx.fillStyle = 'rgba(15,23,42,0.92)';
      ctx.textAlign = 'center';
      ctx.font = '700 16px ui-monospace, monospace';
      ctx.fillText('30 дней', cx, cy - 2);
      ctx.font = '12px ui-monospace, monospace';
      ctx.fillText('структура трат', cx, cy + 16);
      ctx.restore();
    }

    function drawMonthly() {
      var canvas = document.getElementById('llmChartMonthly');
      if (!(canvas instanceof HTMLCanvasElement)) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth;
      var h = canvas.clientHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, w, h);

      var chart = readJson('llmChartData', { dates: [], labels: [], total: [], premium: [], mid: [], budget: [] });
      var padL = 78, padR = 24, padT = 34, padB = 56, chartW = w - padL - padR, chartH = h - padT - padB;
      var maxVal = 1;
      for (var i = 0; i < chart.total.length; i++) { if (chart.total[i] > maxVal) maxVal = chart.total[i]; }

      ctx.save();
      ctx.strokeStyle = 'rgba(148,163,184,0.18)'; ctx.lineWidth = 1; ctx.font = '11px ui-monospace,monospace'; ctx.fillStyle = 'rgba(71,85,105,0.7)'; ctx.textAlign = 'right';
      for (var i = 0; i <= 4; i++) { var y = padT + chartH - (chartH/4)*i; ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(w-padR, y); ctx.stroke(); ctx.fillText(Math.round(maxVal/4*i/1000)+'k', padL-8, y+3); }

      ctx.textAlign = 'center'; var colors = {total: '#0f172a', premium: '#7c3aed', mid: '#06b6d4', budget: '#f59e0b'};
      var fills = {total: 'rgba(15,23,42,0.10)', premium: 'rgba(124,58,237,0.10)', mid: 'rgba(6,182,212,0.10)', budget: 'rgba(245,158,11,0.10)'};
      var series = [ {key:'premium',color:colors.premium,fill:fills.premium,data:chart.premium}, {key:'mid',color:colors.mid,fill:fills.mid,data:chart.mid}, {key:'budget',color:colors.budget,fill:fills.budget,data:chart.budget}, {key:'total',color:colors.total,fill:fills.total,data:chart.total} ];

      for (var s = 0; s < series.length; s++) {
        var item = series[s]; var pts = []; ctx.save(); ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;
        if (!item || !Array.isArray(item.data) || item.data.length === 0) { ctx.restore(); continue; }
        for (var j = 0; j < item.data.length; j++) { var x = padL + (chartW * j) / (item.data.length - 1); var y = padT + chartH - (item.data[j]/maxVal)*chartH; pts.push({x:x, y:y, v:item.data[j]}); }
        var firstPoint = pts[0];
        var lastPoint = pts[pts.length - 1];
        if (!firstPoint || !lastPoint) { ctx.restore(); continue; }
        ctx.fillStyle = item.fill; ctx.beginPath(); ctx.moveTo(firstPoint.x, padT+chartH);
        for (var j = 0; j < pts.length; j++) { var prev = pts[j-1], cur = pts[j]; if (prev) ctx.quadraticCurveTo(prev.x, prev.y, (prev.x+cur.x)/2, (prev.y+cur.y)/2); else ctx.lineTo(cur.x, cur.y); }
        ctx.lineTo(lastPoint.x, padT+chartH); ctx.closePath(); ctx.fill();
        ctx.strokeStyle = item.color; ctx.lineWidth = s === 3 ? 3.2 : 2; ctx.beginPath(); ctx.moveTo(firstPoint.x, firstPoint.y);
        for (var j = 1; j < pts.length; j++) { var prev = pts[j-1], cur = pts[j]; ctx.quadraticCurveTo(prev.x, prev.y, (prev.x+cur.x)/2, (prev.y+cur.y)/2); } ctx.lineTo(lastPoint.x, lastPoint.y); ctx.stroke(); ctx.restore();
      }

      ctx.fillStyle = 'rgba(71,85,105,0.75)'; ctx.font = '11px ui-monospace,monospace'; ctx.textAlign = 'center';
      for (var i = 0; i < chart.labels.length; i++) { var x = padL + (chartW * i) / (chart.labels.length - 1); ctx.fillText(chart.labels[i], x, h - 12); }
      ctx.restore();
    }

    function drawTier() {
      var canvas = document.getElementById('llmChartTier');
      if (!(canvas instanceof HTMLCanvasElement)) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth;
      var h = canvas.clientHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, w, h);

      var chart = readJson('llmChartData', { dates: [], labels: [], total: [], premium: [], mid: [], budget: [] });
      var last = Math.max(0, chart.labels.length - 1);
      var items = [
        { label: 'Premium', value: chart.premium[last] || 0, color: '#7c3aed' },
        { label: 'Mid', value: chart.mid[last] || 0, color: '#06b6d4' },
        { label: 'Budget', value: chart.budget[last] || 0, color: '#f59e0b' }
      ];
      var total = items.reduce(function(s, i) { return s + i.value; }, 0);
      var hoverIndex = -1;
      var cx = w / 2, cy = h / 2 - 10, r = Math.min(w, h) * 0.4, inner = r * 0.68;
      var ring = r - inner;

      function getActiveSlice(x, y) {
        var dx = x - cx;
        var dy = y - cy;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < inner || dist > r) return -1;

        var angle = Math.atan2(dy, dx) + Math.PI / 2;
        if (angle < 0) angle += Math.PI * 2;

        var start = 0;
        for (var i = 0; i < items.length; i++) {
          var slice = total ? (items[i].value / total) * Math.PI * 2 : 0;
          var end = start + slice;
          if (angle >= start && angle <= end) return i;
          start = end;
        }

        return -1;
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);

        var start = -Math.PI / 2;
        for (var i = 0; i < items.length; i++) {
          var item = items[i];
          var slice = total ? (item.value / total) * Math.PI * 2 : 0;
          var mid = start + slice / 2;
          var active = i === hoverIndex;
          ctx.beginPath();
          ctx.strokeStyle = item.color;
          ctx.lineWidth = active ? ring + 2 : ring;
          ctx.lineCap = 'butt';
          ctx.arc(cx, cy, (r + inner) / 2, start, start + slice);
          ctx.stroke();

          if (active) {
            var labelX = cx + Math.cos(mid) * (r + 14);
            var labelY = cy + Math.sin(mid) * (r + 14);
            ctx.beginPath();
            ctx.fillStyle = item.color;
            ctx.arc(labelX, labelY, 4, 0, Math.PI * 2);
            ctx.fill();
          }

          start += slice;
        }

        var activeItem = hoverIndex >= 0 ? items[hoverIndex] : null;
        var activeValue = activeItem ? activeItem.value : total;
        var activeLabel = activeItem ? activeItem.label : 'Итого';
        var activeShare = activeItem && total ? Math.round((activeItem.value / total) * 100) : 100;

        ctx.fillStyle = 'rgba(15,23,42,0.92)';
        ctx.textAlign = 'center';
        ctx.font = '700 20px ui-monospace,monospace';
        ctx.fillText(Math.round(activeValue).toLocaleString('ru-RU') + ' ₽', cx, cy - 6);
        ctx.font = '12px ui-monospace,monospace';
        ctx.fillStyle = 'rgba(71,85,105,0.8)';
        ctx.fillText(activeLabel, cx, cy + 14);
        ctx.fillText(activeShare + '%', cx, cy + 30);
      }

      canvas.style.cursor = 'pointer';
      draw();

      canvas.onmousemove = function(event) {
        var rect = canvas.getBoundingClientRect();
        var nextHover = getActiveSlice(event.clientX - rect.left, event.clientY - rect.top);
        if (nextHover !== hoverIndex) {
          hoverIndex = nextHover;
          draw();
        }
      };

      canvas.onmouseleave = function() {
        if (hoverIndex !== -1) {
          hoverIndex = -1;
          draw();
        }
      };
    }

    function drawModels() {
      var canvas = document.getElementById('llmChartModels');
      if (!(canvas instanceof HTMLCanvasElement)) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth;
      var h = canvas.clientHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, w, h);

      var models = readJson('llmTopModels', []);
      var top = models.slice().sort(function(a, b) { return b.cost - a.cost; }).slice(0, 6);
      var maxVal = Math.max.apply(null, top.map(function(m) { return m.cost; })) || 1;
      var totalCost = top.reduce(function(sum, item) { return sum + item.cost; }, 0) || 1;
      var padL = 132, padR = 24, padT = 22, padB = 42, chartW = w - padL - padR, chartH = h - padT - padB;
      var rowH = chartH / Math.max(1, top.length);
      var barH = Math.max(14, rowH * 0.42);

      ctx.save();
      ctx.font = '11px ui-monospace,monospace';
      ctx.fillStyle = 'rgba(71,85,105,0.7)';
      ctx.textAlign = 'right';
      ctx.strokeStyle = 'rgba(148,163,184,0.18)';
      for (var i = 0; i <= 4; i++) {
        var y = padT + chartH - (chartH / 4) * i;
        ctx.beginPath();
        ctx.moveTo(padL, y);
        ctx.lineTo(w - padR, y);
        ctx.stroke();
        ctx.fillText(Math.round(maxVal / 4 * i / 1000) + 'k', padL - 8, y + 3);
      }
      ctx.restore();

      top.forEach(function(m, i) {
        var y = padT + rowH * i + (rowH - barH) / 2;
        var barW = Math.max(2, (m.cost / maxVal) * chartW);
        var share = Math.round((m.cost / totalCost) * 100);
        ctx.fillStyle = 'rgba(15,23,42,0.88)';
        ctx.font = '11px ui-monospace,monospace';
        ctx.textAlign = 'left';
        ctx.fillText(m.name, 12, y + barH / 2 + 3);

        ctx.fillStyle = m.color;
        ctx.fillRect(padL, y, barW, barH);

        ctx.fillStyle = 'rgba(71,85,105,0.8)';
        ctx.textAlign = 'right';
        ctx.fillText(Math.round(m.cost).toLocaleString('ru-RU') + ' ₽', padL + barW - 8, y + barH / 2 + 3);
        ctx.fillText(share + '%', w - 4, y + barH / 2 + 3);
      });
    }

    function initCharts() {
      drawMonthly();
      drawTier();
      drawModels();
    }

    function loadChart() {
      try {
        initCharts();
      } catch (error) {
        console.error('initCharts failed', error);
      }
      try {
        drawCommitWave();
      } catch (error) {
        console.error('drawCommitWave failed', error);
      }
    }

    function drawCommitWave() {
      var canvas = document.getElementById('commitWaveChart');
      if (!(canvas instanceof HTMLCanvasElement)) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;
      var dpr = window.devicePixelRatio || 1;
      var w = canvas.clientWidth;
      var h = canvas.clientHeight;
      if (!w || !h) return;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, w, h);

      var chart = {dates: [], labels: [], series: []};
      try {
        var shell = document.querySelector('.commit-wave-chart');
        if (shell) chart = JSON.parse(shell.getAttribute('data-commit-wave') || '{}');
      } catch(e) {}

      function formatCommitDay(dateKey) {
        var date = new Date(dateKey + 'T00:00:00Z');
        var months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
        var day = date.getUTCDate();
        return (day < 10 ? '0' : '') + day + ' ' + months[date.getUTCMonth()];
      }

      if (!chart || !chart.dates || !chart.dates.length) return;

      var colors = {
        'UHA-6.0': { line: '#a1a1aa', fill: 'rgba(161, 161, 170, 0.12)' },
        Genius: { line: '#52525b', fill: 'rgba(82, 82, 91, 0.12)' },
        MethodA: { line: '#737373', fill: 'rgba(115, 115, 115, 0.12)' }
      };

      var padL = 52;
      var padR = 24;
      var padT = 26;
      var padB = 44;
      var chartW = w - padL - padR;
      var chartH = h - padT - padB;
      var maxVal = 1;
      var i;

      for (i = 0; i < chart.series.length; i++) {
        var series = chart.series[i];
        for (var j = 0; j < series.values.length; j++) {
          if (series.values[j] > maxVal) maxVal = series.values[j];
        }
      }

      ctx.save();
      ctx.strokeStyle = 'rgba(148, 163, 184, 0.18)';
      ctx.lineWidth = 1;
      ctx.font = '10px ui-monospace, monospace';
      ctx.fillStyle = 'rgba(15,23,42,0.45)';
      ctx.textAlign = 'right';

      for (i = 0; i <= 4; i++) {
        var y = padT + chartH - (chartH / 4) * i;
        ctx.beginPath();
        ctx.moveTo(padL, y);
        ctx.lineTo(w - padR, y);
        ctx.stroke();
        ctx.fillText(String(Math.round((maxVal / 4) * i)), padL - 8, y + 3);
      }

      ctx.textAlign = 'center';
      var tickStep = Math.max(1, Math.floor(chart.dates.length / 5));
      for (i = 0; i < chart.dates.length; i += tickStep) {
        var tickX = padL + (chartW * i) / Math.max(chart.dates.length - 1, 1);
        ctx.fillText(chart.labels[i], tickX, h - 14);
      }

      for (i = 0; i < chart.series.length; i++) {
        var seriesItem = chart.series[i];
        if (!seriesItem || !Array.isArray(seriesItem.values) || seriesItem.values.length === 0) {
          continue;
        }
        var seriesValues = seriesItem.values;
        var seriesName = seriesItem.name;
        var color = colors[seriesName] || { line: '#8b5cf6', fill: 'rgba(139, 92, 246, 0.16)' };
        var points = [];

        for (var k = 0; k < seriesValues.length; k++) {
          var value = seriesValues[k];
          if (value === undefined || value === null) continue;
          var x = padL + (chartW * k) / Math.max(seriesValues.length - 1, 1);
          var yValue = padT + chartH - (value / maxVal) * chartH;
          points.push({ x: x, y: yValue, value: value });
        }

        if (points.length === 0) {
          continue;
        }

        var firstPoint = points[0];
        var lastPoint = points[points.length - 1];
        if (!firstPoint || !lastPoint || typeof firstPoint.x !== 'number' || typeof lastPoint.x !== 'number') {
          console.warn('drawCommitWave: invalid points', { firstPoint, lastPoint });
          continue;
        }

        ctx.save();
        ctx.shadowColor = color.line;
        ctx.shadowBlur = 10;
        ctx.fillStyle = color.fill;
        ctx.beginPath();
        ctx.moveTo(firstPoint.x, padT + chartH);
        ctx.lineTo(firstPoint.x, firstPoint.y);
        for (k = 1; k < points.length; k++) {
          var prev = points[k - 1];
          var current = points[k];
          if (!prev || !current || typeof prev.x !== 'number' || typeof current.x !== 'number') continue;
          var midX = (prev.x + current.x) / 2;
          ctx.quadraticCurveTo(prev.x, prev.y, midX, (prev.y + current.y) / 2);
        }
        ctx.lineTo(lastPoint.x, padT + chartH);
        ctx.closePath();
        ctx.fill();

        ctx.shadowBlur = 0;
        ctx.strokeStyle = color.line;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.moveTo(firstPoint.x, firstPoint.y);
        for (k = 1; k < points.length; k++) {
          prev = points[k - 1];
          current = points[k];
          if (!prev || !current || typeof prev.x !== 'number' || typeof current.x !== 'number') continue;
          midX = (prev.x + current.x) / 2;
          ctx.quadraticCurveTo(prev.x, prev.y, midX, (prev.y + current.y) / 2);
        }
        ctx.lineTo(lastPoint.x, lastPoint.y);
        ctx.stroke();

        ctx.fillStyle = color.line;
        for (k = 0; k < points.length; k++) {
          if (points[k].value <= 0) continue;
          ctx.beginPath();
          ctx.arc(points[k].x, points[k].y, 3.5, 0, Math.PI * 2);
          ctx.fill();
        }

        var peakPoint = firstPoint;
        for (k = 1; k < points.length; k++) {
          if (points[k].value > peakPoint.value) peakPoint = points[k];
        }

        if (peakPoint.value > 0) {
          ctx.fillStyle = '#fff';
          ctx.font = '700 11px ui-monospace, monospace';
          ctx.textAlign = 'left';
          ctx.fillText(seriesName + ' · ' + String(peakPoint.value), peakPoint.x + 8, peakPoint.y - 8);
        }

        ctx.restore();
      }

      ctx.restore();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadChart);
    } else {
      loadChart();
    }
  </script>

