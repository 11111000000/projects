            <div class="analysis-line"><strong>Тезис</strong><span class="tone info">{row.thesis}</span></div>
            <div class="analysis-line"><strong>Антитезис</strong><span class="tone warn">{row.antithesis}</span></div>
            <div class="analysis-line"><strong>Синтез</strong><span class="tone good">{row.synthesis}</span></div>
            
            <div class="mini-section">
              <strong>Фокус</strong>
              <ul>{row.focus.map((item) => <li>{item}</li>)}</ul>
            </div>
            <div class="mini-section">
              <strong>Сигналы</strong>
              <ul>{row.evidence.map((item) => <li>{item}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="stage">
      <header>
        <span class="step-num">06</span>
        <h2>Публикация (Action)</h2>
      </header>
      <div class="wf-grid wf-grid-wide">
        {publicationRows.map(row => (
          <article class="wf-action-card">
            <h3>{row.name}</h3>
            <div class={`verdict-line ${statusClass(row.score)}`}>{row.verdict}</div>
            <p>{row.recommendation}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="stage">
      <header>
        <span class="step-num">07</span>
        <h2>Коммиты и артефакты</h2>
      </header>
      <div class="commit-grid">
        {projects.map((project) => {
          const commitDetails = project.commitDetails || [];
          return (
            <article class="commit-card">
              <h3>{project.name}</h3>
              <p class="commit-note">Полный листинг ключевых коммитов с короткими описаниями.</p>
              <ul>
                {commitDetails.map((commit) => (
                  <li>
                    <strong>{commit.hash}</strong> <span>{commit.date}</span> <em>{commit.title}</em>
                    <div>{commit.description}</div>
                  </li>
                ))}
              </ul>
            </article>
          );
        })}
      </div>
    </section>

  <section class="stage note">
    <h2>Итог исследования</h2>
    <p>
      UHA-6.0 остаётся прототипом, Genius — зрелым движком, MethodA — docs-first системой.
      Все проценты теперь связаны с источниками и разложены по плану/факту.
    </p>
  </section>

  <section class="stage">
    <header>
      <span class="step-num">08</span>
      <h2>Сводные статьи</h2>
    </header>
    <div class="summary-article-grid">
      {projectSummaries.map((project) => (
        <article class="summary-article">
          <div class={`badge ${project.name === 'UHA-6.0' ? 'warn' : project.name === 'Genius' ? 'info' : 'good'}`}>{project.status}</div>
          <h3>{project.name}</h3>
          <p>{project.summary}</p>
          <p class="summary-unique">{project.unique}</p>
          <a href={`/projects/${project.slug}`}>Открыть проект</a>
        </article>
      ))}
    </div>
  </section>

  </div>
</BaseLayout>

