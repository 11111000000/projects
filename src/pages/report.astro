<script>
  // Handlers for ProjectDiagramCard.astro (using data-diagram-*)
  const diagramCards = document.querySelectorAll('[data-diagram-card]');
  diagramCards.forEach((card) => {
    const valueEl = card.querySelector('[data-diagram-value]');
    const labelEl = card.querySelector('[data-diagram-label]');
    const ringCircle = card.querySelector('circle[data-diagram-ring]') as SVGCircleElement | null;
    const buttons = card.querySelectorAll('[data-diagram-button]');
    
    const colors = { progress: '#2563eb', hologram: '#8b5cf6', spec: '#14b8a6' };
    const radius = 52;
    const circumference = 2 * Math.PI * radius;

    const setActive = (button) => {
      const value = parseInt(button.getAttribute('data-value') || '0', 10);
      const target = button.getAttribute('data-target');
      
      buttons.forEach(b => b.classList.toggle('is-active', b === button));
      
      if (valueEl) valueEl.textContent = `${value}%`;
      if (labelEl) {
        labelEl.textContent = target === 'progress' ? 'Итог' : target === 'hologram' ? 'Голограмма' : 'Спека';
      }
      
      if (ringCircle) {
        ringCircle.style.stroke = colors[target] || colors.progress;
        const offset = circumference * (1 - value / 100);
        ringCircle.style.strokeDashoffset = offset.toString();
      }
    };

    buttons.forEach((button) => {
      button.addEventListener('mouseenter', () => setActive(button));
      button.addEventListener('click', () => setActive(button));
    });
    
    const firstButton = buttons.item(0);
    if (firstButton) setActive(firstButton);
  });
</script>
