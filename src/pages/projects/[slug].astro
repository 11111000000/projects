---
// @ts-nocheck
import BaseLayout from '../../layouts/BaseLayout.astro';
import DashboardSidebar from '../../components/DashboardSidebar.astro';
import ProjectHealthDashboard from '../../components/ProjectHealthDashboard.astro';
import { loadProjectResearch } from '../../lib/project-research.js';
import { catalog } from '../../lib/catalog.js';

export function getStaticPaths() {
  return catalog.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const research = await loadProjectResearch();
const resolvedProject = research.projects.find((item) => item.slug === project.slug) || project;

function formatMonthKey(monthKey) {
  const [year, month] = monthKey.split('-').map(Number);
  return new Intl.DateTimeFormat('ru-RU', { month: 'short', year: 'numeric' }).format(
    new Date(Date.UTC(year, month - 1, 1))
  );
}

function shiftMonthKey(monthKey, delta) {
  const [year, month] = monthKey.split('-').map(Number);
  const date = new Date(Date.UTC(year, month - 1 + delta, 1));
  return `${date.getUTCFullYear()}-${String(date.getUTCMonth() + 1).padStart(2, '0')}`;
}

function buildTwoMonthActivity(commitDetails = []) {
  const counts = new Map();
  commitDetails.forEach((commit) => {
    const monthKey = commit.date.slice(0, 7);
    counts.set(monthKey, (counts.get(monthKey) || 0) + 1);
  });

  const sortedMonths = [...counts.keys()].sort();
  const latestMonth = sortedMonths[sortedMonths.length - 1] || '2026-04';
  const previousMonth = sortedMonths[sortedMonths.length - 2] || shiftMonthKey(latestMonth, -1);
  const monthKeys = [previousMonth, latestMonth];

  return monthKeys.map((monthKey) => ({
    key: monthKey,
    label: formatMonthKey(monthKey),
    count: counts.get(monthKey) || 0,
    percent: 0
  }));
}

const projectMonths = buildTwoMonthActivity(resolvedProject.commitDetails || []);
const projectMax = Math.max(...projectMonths.map((month) => month.count), 1);
const projectActivityMonths = projectMonths.map((month) => ({
  ...month,
  percent: Math.round((month.count / projectMax) * 100)
}));

const articleNotes = [
  resolvedProject.name === 'UHA-6.0'
    ? 'Boundary-first Android-прототип с сильным каркасом, но ещё без полного domain bridge и p2p.'
    : resolvedProject.name === 'Genius'
      ? 'Зрелый графовый движок, где runtime и layout сильны, но продуктовый контур ещё не доведён.'
      : 'Docs-first система, где канон, протоколы и verification уже сформировали рабочий контур.',
  resolvedProject.name === 'UHA-6.0'
    ? 'Сильные стороны: навигация, storage/net/maps и LIVE-SOLO. Слабое место: функциональная завершённость.'
    : resolvedProject.name === 'Genius'
      ? 'Сильные стороны: engine, tests, layout. Слабое место: complex families, LOD, gestures.'
      : 'Сильные стороны: living document, emacs-mode, verification. Слабое место: интеграция и UX.'
];

const article = resolvedProject.article || {
  lead: resolvedProject.summary,
  purpose: 'Описание проекта пока не сформировано.',
  built: resolvedProject.doneItems || [],
  done: resolvedProject.doneItems || [],
  next: resolvedProject.nextItems || [],
  assessment: resolvedProject.scoreNote || ''
};
---

<BaseLayout title={`${resolvedProject.name} · ProjectsReview`} description={`Страница проекта ${resolvedProject.name}`}>
  <Fragment slot="topbar">
    <div>
      <div class="eyebrow">Проект</div>
      <h1>{resolvedProject.name}</h1>
      <p class="lead">{resolvedProject.summary}</p>
    </div>
  </Fragment>

  <Fragment slot="sidebar">
    <DashboardSidebar projects={research.projects} active={resolvedProject.slug} />
  </Fragment>

  <section class="metrics">
    <div class="tile"><strong>{resolvedProject.progress}%</strong><span>Выполнение</span></div>
    <div class="tile"><strong>{resolvedProject.hologramProgress}%</strong><span>Голограмма</span></div>
    <div class="tile"><strong>{resolvedProject.specProgress}%</strong><span>Спека</span></div>
    <div class="tile"><strong>{resolvedProject.risk}%</strong><span>Риск</span></div>
    <div class="tile"><strong>{resolvedProject.totalDone}/{resolvedProject.totalVolume}</strong><span>Объём факт/план</span></div>
  </section>

  <section class="diagram-section">
    <ProjectHealthDashboard
      name={resolvedProject.name}
      progress={resolvedProject.progress}
      hologram={resolvedProject.hologramProgress}
      spec={resolvedProject.specProgress}
      done={resolvedProject.totalDone}
      total={resolvedProject.totalVolume}
      commitDetails={resolvedProject.commitDetails || []}
      gantt={resolvedProject.gantt || []}
      compact={true}
    />
  </section>

  <section class="panel project-article-panel">
    <h2>Статья о проекте</h2>
    <p>{article.lead}</p>
    <p>{article.philosophy}</p>
    <p>{article.purpose}</p>
    <p>{article.structure}</p>
    <p>{article.device}</p>
    <div class="article-grid">
      <article>
        <strong>Что построено</strong>
        <ul>{article.built.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article>
        <strong>Что важно удержать</strong>
        <ul>{(article.tasks || article.next || []).map((item) => <li>{item}</li>)}</ul>
      </article>
      <article>
        <strong>Что уже сделано</strong>
        <ul>{article.done.map((item) => <li>{item}</li>)}</ul>
      </article>
    </div>
    <p>{article.tradeoffs}</p>
    <p class="article-assessment">{article.assessment}</p>
    {article.sources?.length ? (
      <div class="article-sources">
        <strong>Источники</strong>
        <ul>
          {article.sources.map((source) => (
            <li><code>{source.path}</code> - {source.note}</li>
          ))}
        </ul>
      </div>
    ) : null}
  </section>

  <section class="status-legend">
    <span class={`status-pill ${resolvedProject.statusTone}`}>{resolvedProject.status}</span>
    <span class="status-pill good">ЗАВЕРШЕНО</span>
    <span class="status-pill warn">В ПРОЦЕССЕ</span>
    <span class="status-pill info">ДОКУМЕНТАЦИЯ</span>
    <span class="status-pill danger">РИСК</span>
  </section>

  <section class="panel hologram-panel">
    <h2>Архитектурный слой</h2>
    <p class="holo-state">{resolvedProject.hologramState}</p>
    <p class="holo-summary">{resolvedProject.hologramSummary}</p>
      <div class="holo-grid">
        <div>
        <strong>Документы</strong>
        <p>{resolvedProject.hologramState}</p>
        </div>
        <div>
        <strong>Спека</strong>
        <p>{resolvedProject.specState}</p>
        </div>
      </div>
      <div class="holo-grid lower">
        <div>
          <strong>Ядро</strong>
          <p>{resolvedProject.starterState}</p>
        </div>
        <div>
          <strong>Формула зрелости</strong>
          <p>{resolvedProject.progressModel ? `Г ${resolvedProject.progressModel.hologramDone}/${resolvedProject.progressModel.hologramTotal}, С ${resolvedProject.progressModel.specDone}/${resolvedProject.progressModel.specTotal}` : 'нет данных'}</p>
        </div>
      </div>
    </section>

  <section class="layout-block">
    <div class="panel info">
      <h2>Код</h2>
      <ul>{resolvedProject.codeDigest.map((item) => <li>{item}</li>)}</ul>
    </div>
    <div class="panel good">
      <h2>Голограмма (документы)</h2>
      <ul>{resolvedProject.holoDigest.map((item) => <li>{item}</li>)}</ul>
    </div>
  </section>

  <section class="layout-block">
    <div class="panel good">
      <h2>Сделано</h2>
      <ul>{resolvedProject.doneItems.map((item) => <li>{item}</li>)}</ul>
    </div>
    <div class="panel warn">
      <h2>Дальше</h2>
      <ul>{resolvedProject.nextItems.map((item) => <li>{item}</li>)}</ul>
    </div>
  </section>

  <section class="layout-block">
    <div class="panel danger">
      <h2>Риски</h2>
      <ul>{resolvedProject.riskItems.map((item) => <li>{item}</li>)}</ul>
    </div>
    <div class="panel info">
      <h2>Контекст</h2>
      <ul>{resolvedProject.detailItems.map((item) => <li>{item}</li>)}</ul>
    </div>
  </section>

  <section class="panel timeline-panel">
    <h2>Этапы и переходы</h2>
    <div class="timeline-grid">
      {resolvedProject.timeline.map((label, index) => {
        let statusText = 'ОЖИДАНИЕ';
        let statusClass = 'warn';
        if (index < 2) {
          statusText = 'ЗАВЕРШЕНО';
          statusClass = 'good';
        } else if (index === 2) {
          statusText = 'В ПРОЦЕССЕ';
          statusClass = 'warn';
        }

        return (
          <div class="timeline-row" title={`${label}: ${statusText}`}>
            <span class="timeline-label">{label}</span>
            <div class="track">
              {Array.from({ length: 10 }, (_, i) => {
                const stepStatus = i < (index * 2 + 1) ? 'done' : (i === index * 2 + 1 ? 'active' : 'next');
                return <span class={`slot ${stepStatus}`}></span>;
              })}
            </div>
            <span class={`status-tag ${statusClass}`}>{statusText}</span>
          </div>
        );
      })}
    </div>
  </section>

  <section class="panel commit-panel">
    <h2>Коммиты</h2>
    <ul class="commit-list">
      {resolvedProject.commits.map((commit) => (
        <li>
          <strong>{commit.hash}</strong>
          <span>{commit.date}</span>
          <em>{commit.title}</em>
          <p>{commit.description}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="panel source-panel">
    <h2>Источники и пруфы</h2>
    <ul class="commit-list">
      {resolvedProject.sourceFiles.map((file) => (
        <li><strong>FILE</strong><span>{file}</span></li>
      ))}
      {resolvedProject.holoDigest.map((item) => (
        <li><strong>HOLO</strong><span>{item}</span></li>
      ))}
      {resolvedProject.doneItems.slice(0, 3).map((item) => (
        <li><strong>FACT</strong><span>{item}</span></li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .eyebrow { text-transform: uppercase; letter-spacing: 0.12em; font-size: 12px; color: var(--muted); }
  h1 { margin: 8px 0 0; font-size: clamp(2rem, 4vw, 3rem); font-family: inherit; }
  .lead { margin: 8px 0 0; color: var(--muted); line-height: 1.6; max-width: 72ch; font-family: inherit; }
  .metrics, .layout-block { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin-top: 16px; }
  .layout-block { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .tile, .panel { border: 1px solid var(--line); background: var(--panel); padding: 14px; border-radius: 0; }
  .tile { display: grid; gap: 4px; }
  .panel.good { border-color: #10b981; background: rgba(16,185,129,0.06); }
  .panel.warn { border-color: #f59e0b; background: rgba(245,158,11,0.06); }
  .panel.info { border-color: #3b82f6; background: rgba(59,130,246,0.06); }
  .panel.danger { border-color: #ef4444; background: rgba(239,68,68,0.06); }
  .tile strong { display: block; font-size: 1.5rem; font-family: inherit; }
  .tile span { color: var(--muted); }
  .tile:nth-child(1) { border-color: #10b981; }
  .tile:nth-child(2) { border-color: #3b82f6; }
  .tile:nth-child(3) { border-color: #ef4444; }
  .tile:nth-child(4) { border-color: #f59e0b; }
  .panel h2 { margin: 0 0 16px; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid var(--line); padding-bottom: 8px; font-family: inherit; }
  .panel.good h2 { color: #10b981; }
  .panel.warn h2 { color: #f59e0b; }
  .panel.info h2 { color: #3b82f6; }
  .panel.danger h2 { color: #ef4444; }
  .project-article-panel { margin-top: 16px; border-color: #8b5cf6; background: color-mix(in oklab, var(--panel) 96%, var(--line) 4%); }
  .project-article-panel h2 { margin: 0 0 12px; text-transform: uppercase; font-size: 0.95rem; border-bottom: 1px solid var(--line); padding-bottom: 8px; }
  .project-article-panel p { margin: 0 0 8px; color: var(--muted); line-height: 1.6; }
  .article-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-top: 12px; }
  .article-grid article { border: 1px solid var(--line); padding: 12px; background: var(--panel); }
  .article-grid strong { display: block; margin-bottom: 8px; text-transform: uppercase; font-size: 0.78rem; color: var(--muted); }
  .article-grid ul { margin: 0; padding-left: 18px; color: var(--text); display: grid; gap: 6px; }
  .article-assessment { margin-top: 12px; font-weight: 600; color: var(--text); }
  .article-sources { margin-top: 16px; border-top: 1px solid var(--line); padding-top: 12px; }
  .article-sources strong { display: block; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.8rem; }
  .article-sources ul { margin: 0; padding-left: 18px; display: grid; gap: 6px; }
  .article-sources code { font-family: ui-monospace, monospace; font-size: 0.9em; }
  .hologram-panel { border-color: #3b82f6; }
  .holo-state { font-weight: 700; margin: 0 0 8px; color: #3b82f6; text-transform: uppercase; font-size: 0.9rem; }
  .holo-summary { margin: 0 0 16px; color: var(--muted); line-height: 1.6; }
  .holo-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
  .holo-grid.lower { margin-top: 16px; }
  .holo-grid strong { display: block; margin-bottom: 6px; color: #10b981; text-transform: uppercase; font-size: 0.78rem; }
  .holo-grid p { margin: 0; color: var(--muted); line-height: 1.5; font-size: 0.9rem; }
  
  ul { margin: 0; padding-left: 18px; color: var(--text); }
  li + li { margin-top: 6px; }

  .timeline-panel { margin-top: 24px; }
  .timeline-grid { display: grid; gap: 12px; }
  .timeline-row { 
    display: grid; 
    grid-template-columns: 180px 1fr 120px; 
    gap: 20px; 
    align-items: center; 
    padding: 8px;
    border: 1px solid transparent;
    transition: background 0.2s, border-color 0.2s;
    cursor: default;
  }
  .timeline-row:hover {
    background: var(--bg);
    border-color: var(--line-soft);
  }

  .timeline-label { font-size: 0.9rem; font-weight: bold; }
  .track { display: grid; grid-template-columns: repeat(10, 1fr); gap: 4px; }
  
  .slot { height: 8px; border: 1px solid var(--line-soft); }
  .slot.done { background: var(--line); border-color: var(--line); }
  .slot.active { 
    background: var(--text); 
    border-color: var(--line);
    animation: pulse 2s infinite;
  }
  .slot.next { background: transparent; }

  .status-tag { font-size: 0.75rem; text-transform: uppercase; color: var(--muted); text-align: right; }
  .status-tag.good { color: #10b981; }
  .status-tag.warn { color: #f59e0b; }
  .status-tag.info { color: #3b82f6; }
  .status-tag.danger { color: #ef4444; }
  .status-legend { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
  .status-pill { display: inline-flex; width: fit-content; padding: 4px 10px; border: 1px solid var(--line); text-transform: uppercase; font-size: 0.78rem; }
  .status-pill.good { color: #10b981; border-color: #10b981; background: rgba(16,185,129,0.12); }
  .status-pill.warn { color: #f59e0b; border-color: #f59e0b; background: rgba(245,158,11,0.12); }
  .status-pill.info { color: #3b82f6; border-color: #3b82f6; background: rgba(59,130,246,0.12); }
  .status-pill.danger { color: #ef4444; border-color: #ef4444; background: rgba(239,68,68,0.12); }
  .commit-list em { color: #3b82f6; font-style: normal; }
  .commit-panel { margin-top: 16px; border-color: #3b82f6; }
  .commit-list { display: grid; gap: 12px; margin: 0; padding-left: 18px; }
  .commit-list li { display: grid; gap: 4px; }
  .commit-list strong { color: #3b82f6; }
  .commit-list span { color: var(--muted); }
  .commit-list p { margin: 0; color: var(--muted); }
  .source-panel span { color: var(--muted); }

  @keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.4; }
    100% { opacity: 1; }
  }

  @media (max-width: 980px) { 
    .metrics, .layout-block { grid-template-columns: 1fr; } 
    .article-grid { grid-template-columns: 1fr; }
    .timeline-row { grid-template-columns: 1fr auto; gap: 8px; }
    .track { order: 3; grid-column: span 2; }
  }
</style>
