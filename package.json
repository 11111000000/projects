{
  "name": "projects-review",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:host": "astro dev --host 0.0.0.0",
    "build": "astro build && npm run stats:collect",
    "stats:llm": "node scripts/collect-llm-stats.mjs",
    "stats:projects": "node scripts/collect-project-activity.mjs",
    "stats:collect": "npm run stats:llm && npm run stats:projects",
    "preview": "astro preview",
    "preview:host": "astro preview --host 0.0.0.0",
    "start": "astro preview --host 0.0.0.0"
  },
  "dependencies": {
    "astro": "^4.16.19",
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  }
}
